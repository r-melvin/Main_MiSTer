; launcher.cfg.example
; Copy the relevant lines into /media/fat/MiSTer.ini under the [MiSTer] section.
; All launcher settings are optional unless noted.

[MiSTer]

; ── Core launcher ─────────────────────────────────────────────────────────────

; Enable the game launcher UI (default: 1)
LAUNCHER=1

; Directory on the SD card used for launcher data: cache, covers, themes, state.
; Created automatically if it does not exist. (default: /media/fat/launcher)
LAUNCHER_PATH=/media/fat/launcher

; Root directory containing system subdirectories with ROMs. Shared with
; MiSTer's stock menu by default. (default: /media/fat/games)
LAUNCHER_GAMES_PATH=/media/fat/games

; Enable particle background animation. Set to 0 to save ~2 ms/frame. (default: 1)
LAUNCHER_PARTICLES=1

; Theme to use. Must match a subdirectory name inside {LAUNCHER_PATH}/themes/.
; Built-in options: dark  light  purple  retro  (default: dark)
LAUNCHER_THEME=dark
